# Bible API - PostgreSQL local sem Docker

# Django
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bible_api
DB_USER=postgres
DB_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/bible_api

# Redis local
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1

# API
API_VERSION=v1
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI / RAG
OPENAI_API_KEY=
RAG_ALLOWED_VERSIONS=PT_NAA,PT_ARA,PT_NTLH,EN_KJV
RAG_HYBRID=1
RAG_HYBRID_ALPHA=0.5
RAG_RERANK_LARGE=1
EMBEDDING_BATCH_SIZE=128

# pgvector tuning
PG_IVFFLAT_PROBES=10
PG_HNSW_EF_SEARCH=40
